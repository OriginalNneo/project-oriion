# Quorum backend configuration (12-factor — copy to .env and edit).
# Every pipeline stage backend is chosen here, not in code.

# --- Pipeline backends ---
QUORUM_STT_BACKEND=mock          # mock | local | groq
QUORUM_LLM_BACKEND=mock          # mock | local | groq
QUORUM_VAD_BACKEND=mock          # mock | local

# --- Latency knobs ---
QUORUM_VAD_SILENCE_MS=300        # endpointing silence window (lower = snappier)

# --- Cloud creds (only needed when a backend above is `groq`) ---
# QUORUM_GROQ_API_KEY=

# --- Local model choices (only when backend is `local`) ---
QUORUM_WHISPER_MODEL=small       # tiny | base | small | medium
QUORUM_OLLAMA_MODEL=llama3.2:3b

# --- Server ---
QUORUM_HOST=0.0.0.0
QUORUM_PORT=8000
QUORUM_LOG_LEVEL=INFO
QUORUM_LOG_JSON=false            # true for structured JSON logs (prod)
